---
import content from '../../content.ts';
import LeadForm from '../ui/LeadForm.astro';
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/hero/hero-bg.jpg';

const { company_name, company_phone, phrases } = content;
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImg}
      alt=""
      class="w-full h-full object-cover"
      widths={[640, 1024, 1920, 2560]}
      sizes="100vw"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/75 to-black/50 z-10"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column - Headline & CTA -->
      <div class="text-white">
        <h1 class="font-heading font-extrabold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          Professional Painting Services You Can <span class="text-brand-primary">Trust</span>
        </h1>
        
        <p class="text-lg md:text-xl mb-4 leading-relaxed opacity-90">
          {phrases[0]}
        </p>
        <p class="text-base md:text-lg mb-8 leading-relaxed opacity-80">
          {company_name} has been transforming homes and businesses across Delaware for 14 years. Quality craftsmanship at competitive prices.
        </p>

        <!-- Trust Indicators -->
        <div class="flex flex-wrap gap-4 mb-8">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-primary" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
            <span class="text-sm font-medium">14 Years Experience</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-primary" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
            <span class="text-sm font-medium">Free Estimates</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-primary" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
            <span class="text-sm font-medium">Residential & Commercial</span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`tel:${company_phone[0].replace(/[^0-9+]/g, '')}`} class="inline-flex items-center justify-center gap-2 bg-brand-primary hover:bg-brand-primary/90 text-white font-semibold px-8 py-4 rounded-lg transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call Now
          </a>
          <a href="#services" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-brand-dark font-semibold px-8 py-4 rounded-lg transition-colors">
            View Our Services
          </a>
        </div>
      </div>

      <!-- Right Column - Lead Form -->
      <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl p-6 md:p-8">
        <div class="text-center mb-6">
          <h2 class="font-heading font-bold text-2xl text-brand-dark mb-2">Get a Free Quote</h2>
          <p class="text-gray-600 text-sm">Fill out the form below and we'll get back to you within 24 hours</p>
        </div>
        <LeadForm />
      </div>
    </div>
  </div>
</section>
