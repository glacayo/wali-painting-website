---
import content from '../../content.ts';

const { company_phone, company_email, social_media } = content;
---

<div class="bg-brand-dark text-white text-sm py-2 px-4">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">

    <!-- Left: Phone numbers -->
    <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
      {company_phone.map((phone) => (
        <a href={`tel:${phone.replace(/[^0-9+]/g, '')}`} class="flex items-center gap-2 hover:text-brand-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span>{phone}</span>
        </a>
      ))}
    </div>

    <!-- Right: Email + Facebook -->
    <div class="flex items-center gap-6">
      <a href={`mailto:${company_email[0]}`} class="flex items-center gap-2 hover:text-brand-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span>{company_email[0]}</span>
      </a>

      {social_media.facebook !== 'NO FACEBOOK' && social_media.facebook && (
        <a href={social_media.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-brand-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      )}
    </div>

  </div>
</div>
