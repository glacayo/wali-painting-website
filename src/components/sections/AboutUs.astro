---
import content from '../../content.ts';
import { Image } from 'astro:assets';
import aboutImg from '../../assets/images/about/about.jpg';
---

<section id="about" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Image -->
      <div class="order-2 lg:order-1">
        <Image 
          src={aboutImg} 
          alt="Wali Painting - Professional Exterior Work" 
          class="rounded-xl shadow-2xl w-full object-cover aspect-[4/3]"
        />
      </div>

      <!-- Content -->
      <div class="order-1 lg:order-2">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-brand-dark mb-4">
          About {content.company_name}
        </h2>
        
        <div class="w-20 h-1 bg-brand-primary mb-6"></div>
        
        {content.about_content.map((paragraph) => (
          <p class="text-gray-600 leading-relaxed mb-4" set:html={paragraph} />
        ))}

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mt-10">
          <div class="text-center p-4 bg-white rounded-xl shadow-sm">
            <span class="text-4xl font-bold text-brand-primary">14+</span>
            <p class="text-sm text-gray-600 mt-1">Years Experience</p>
          </div>
          <div class="text-center p-4 bg-white rounded-xl shadow-sm">
            <span class="text-4xl font-bold text-brand-primary">500+</span>
            <p class="text-sm text-gray-600 mt-1">Projects Done</p>
          </div>
          <div class="text-center p-4 bg-white rounded-xl shadow-sm">
            <span class="text-4xl font-bold text-brand-primary">100%</span>
            <p class="text-sm text-gray-600 mt-1">Satisfaction</p>
          </div>
        </div>

        <!-- Service Areas -->
        <div class="mt-10 p-6 bg-white rounded-xl shadow-sm">
          <h3 class="font-heading font-bold text-lg text-brand-dark mb-3">Service Areas</h3>
          <p class="text-gray-600 text-sm">{content.company_cover_area}</p>
        </div>

        <a href="#contact" class="inline-flex items-center gap-2 mt-8 bg-brand-primary hover:bg-brand-primary/90 text-white font-semibold px-8 py-4 rounded-lg transition-colors">
          Contact Us Today
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
