---
import BaseLayout from "../layouts/BaseLayout.astro";
import content from "../content.ts";

const { company_name, company_phone, social_media } = content;
---

<BaseLayout
  title={`Thank You | ${company_name}`}
  description="Thank you for contacting us. We'll get back to you shortly."
>
  <div
    class="min-h-screen bg-brand-light flex flex-col items-center justify-center px-4"
  >
    <div
      class="bg-white rounded-2xl shadow-xl max-w-lg w-full text-center py-10 px-10"
    >
      <!-- Checkmark icon -->
      <div
        class="w-20 h-20 bg-brand-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-10 h-10 text-brand-primary"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <h1 class="font-heading font-bold text-3xl text-brand-dark mb-3">
        Thank You!
      </h1>
      <p class="text-gray-600 text-lg mb-2">Your message has been received.</p>
      <p class="text-gray-500 mb-8">
        We'll get back to you within <strong class="text-brand-dark"
          >24 hours</strong
        >. If you need immediate assistance, feel free to call us directly.
      </p>

      <!-- Phone CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
        {
          content.company_phone.map((phone) => (
            <a
              href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
              class="inline-flex items-center justify-center gap-2 bg-brand-primary hover:bg-brand-primary/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
              {phone}
            </a>
          ))
        }
      </div>

      <!-- Back home -->
      <a
        href="/"
        class="inline-flex items-center gap-2 text-brand-primary font-semibold hover:underline transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Home
      </a>

      <!-- Facebook -->
      {
        social_media.facebook !== "NO FACEBOOK" && social_media.facebook && (
          <div class="mt-8 pt-6 border-t border-gray-100">
            <p class="text-sm text-gray-500 mb-3">Follow us on social media</p>
            <a
              href={social_media.facebook}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              class="inline-flex items-center gap-2 text-gray-500 hover:text-brand-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
              <span class="text-sm font-medium">Follow us on Facebook</span>
            </a>
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>
