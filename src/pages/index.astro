---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/layout/TopBar.astro';
import Navbar from '../components/layout/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import Welcome from '../components/sections/Welcome.astro';
import Services from '../components/sections/Services.astro';
import Gallery from '../components/sections/Gallery.astro';
import AboutUs from '../components/sections/AboutUs.astro';
import MissionVisionValues from '../components/sections/MissionVisionValues.astro';
import ContactUs from '../components/sections/ContactUs.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-brand-primary text-white px-4 py-2 rounded z-50">
    Skip to content
  </a>
  
  <TopBar />
  <Navbar />
  
  <main id="main-content">
    <Hero />
    <Welcome />
    <Services />
    <Gallery />
    <AboutUs />
    <MissionVisionValues />
    <ContactUs />
  </main>
  
  <Footer />
</BaseLayout>
