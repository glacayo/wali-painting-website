---
import content from '../../content.ts';
---

<section id="contact" class="py-20 bg-brand-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-brand-dark mb-4">Contact Us</h2>
      <div class="w-20 h-1 bg-brand-primary mx-auto mb-6"></div>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Ready to start your project? Get in touch and we'll get back to you within 24 hours.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div class="bg-white rounded-xl shadow-lg p-6 md:p-8">
        <h3 class="font-heading font-bold text-2xl text-brand-dark mb-6">Send Us a Message</h3>
        
        <form name="contact-form" method="POST" data-netlify="true" action="/thank-you" class="space-y-5">
          <input type="hidden" name="form-name" value="contact-form" />
          
          <div>
            <label for="contact-name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
            <input type="text" id="contact-name" name="name" required placeholder="Your full name" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-colors" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
              <input type="tel" id="contact-phone" name="phone" required placeholder="(555) 000-0000" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-colors" />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" id="contact-email" name="email" required placeholder="you@example.com" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-colors" />
            </div>
          </div>

          <div>
            <label for="contact-message" class="block text-sm font-medium text-gray-700 mb-1">Message / Project Details</label>
            <textarea id="contact-message" name="message" rows="5" required placeholder="Tell us about your project..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-colors resize-none"></textarea>
          </div>

          <button type="submit" class="w-full bg-brand-primary hover:bg-brand-primary/90 text-white font-semibold py-4 rounded-lg transition-colors">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Info & Map -->
      <div class="space-y-6">
        <!-- Google Map -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3116.8!2d-75.38!3d38.69!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDQxJzI2LjEiTiA3NcKwMjInNDMuMyJX!5e0!3m2!1sen!2sus!4v1"
            width="100%"
            height="350"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full"
          ></iframe>
        </div>

        <!-- Contact Info Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-white rounded-xl shadow-md p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-brand-dark mb-1">Address</h4>
              <p class="text-gray-600 text-sm">{content.company_address}</p>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-md p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-brand-dark mb-1">Phone</h4>
              <p class="text-gray-600 text-sm">{content.company_phone[0]}</p>
              {content.company_phone[1] && <p class="text-gray-600 text-sm">{content.company_phone[1]}</p>}
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-md p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-brand-dark mb-1">Email</h4>
              <p class="text-gray-600 text-sm">{content.company_email[0]}</p>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-md p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-brand-dark mb-1">Hours</h4>
              <p class="text-gray-600 text-sm">{content.company_schedule[0]}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
